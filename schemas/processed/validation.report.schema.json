{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "validation.report",
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "snapshot_date",
    "generated_at",
    "status",
    "checks",
    "issues",
    "outputs",
    "summary"
  ],
  "properties": {
    "artifact_type": {"const": "validation.report"},
    "schema_version": {"type": "string"},
    "snapshot_date": {"type": "string"},
    "generated_at": {"type": "string"},
    "status": {"type": "string", "enum": ["ok", "ok_with_warnings", "error"]},
    "checks": {"type": "object"},
    "issues": {"type": "array"},
    "outputs": {"type": "object"},
    "summary": {
      "type": "object",
      "required": ["error_count", "warning_count", "info_count"],
      "properties": {
        "error_count": {"type": "integer", "minimum": 0},
        "warning_count": {"type": "integer", "minimum": 0},
        "info_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
