# Anthropic API key for recommendation generation
ANTHROPIC_API_KEY=

# Optional model override (default: claude-sonnet-4-5-20250929)
POKEPOCKETPEDIA_ANTHROPIC_MODEL=

# Optional custom skill config for Anthropic Skills API
POKEPOCKETPEDIA_ANTHROPIC_SKILL_ID=
POKEPOCKETPEDIA_ANTHROPIC_SKILL_VERSION=
POKEPOCKETPEDIA_ANTHROPIC_DEBUG=0

# For CLI recommend command
POKEPOCKETPEDIA_RECOMMEND_DECK_SLUG=
